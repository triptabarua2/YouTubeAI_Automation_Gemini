# =============================================
# .env.example — এই ফাইল কপি করে .env বানাও
# cp .env.example .env
# তারপর নিচের keys বসাও
# =============================================

# Groq API (Script generation - FREE)
# https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# ElevenLabs (Voice - মাসে 10,000 chars ফ্রি)
# https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID_BN=your_bengali_voice_id_here
ELEVENLABS_VOICE_ID_EN=your_english_voice_id_here
ELEVENLABS_VOICE_ID_HI=DpnM70iDHNHZ0Mguv6GJ

# Google Cloud TTS (Backup voice - মাসে 1M chars ফ্রি)
# https://console.cloud.google.com
GOOGLE_CLOUD_TTS_API_KEY=optional_google_cloud_key

# YouTube OAuth (Upload এর জন্য)
# console.cloud.google.com থেকে JSON ডাউনলোড করো
# client_secret_channel1.json, client_secret_channel2.json, client_secret_channel3.json

# Telegram (নোটিফিকেশন - optional)
TELEGRAM_BOT_TOKEN=optional_telegram_bot_token
TELEGRAM_CHAT_ID=optional_telegram_chat_id

# Pixabay (Background music - optional)
PIXABAY_API_KEY=optional_pixabay_key
